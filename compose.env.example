# Copy this file to compose.env before starting the stack.

# GitHub Container Registry owner/organization and tag to deploy.
GHCR_OWNER=mrworf
DMARC_IMAGE_TAG=main

# Public host ports.
DMARC_WEB_PORT=3000
DMARC_API_PORT=8000

# Session secret is required in any non-development deployment.
DMARC_SESSION_SECRET=replace-with-a-long-random-secret

# Public browser/API origins for split-origin deployments.
DMARC_FRONTEND_PUBLIC_ORIGIN=http://localhost:3000
DMARC_CORS_ALLOWED_ORIGINS=http://localhost:3000
DMARC_API_PUBLIC_URL=http://localhost:8000

# Cookie defaults are suitable for local HTTP. Switch secure=true behind HTTPS.
DMARC_SESSION_COOKIE_SECURE=false
DMARC_SESSION_COOKIE_SAME_SITE=lax
DMARC_CSRF_COOKIE_SAME_SITE=strict

# Optional archive and GeoIP settings.
DMARC_ARCHIVE_STORAGE_PATH=/app/archive
DMARC_GEOIP_PROVIDER=none
DMARC_GEOIP_DATABASE_PATH=
DMARC_GEOIP_BIND_PATH=./data/geoip

# Optional frontend overrides.
NEXT_PUBLIC_API_BASE_URL=http://api:8000
NEXT_PUBLIC_CSRF_COOKIE_NAME=dmarc_csrf
NEXT_PUBLIC_REQUEST_ID_HEADER_NAME=X-Request-ID

# Optional reverse-proxy hosts used by compose.override.proxy.yaml.
DMARC_FRONTEND_HOST=localhost
DMARC_API_HOST=api.localhost
DMARC_PROXY_HTTP_PORT=80
DMARC_PROXY_HTTPS_PORT=443
